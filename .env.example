# ─────────────────────────────────────────────
#  Smart Helmet Backend — Environment Variables
# ─────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# Database
DATABASE_URL="postgresql://helmet_user:helmet_pass@localhost:5432/smart_helmet_db?schema=public"

# JWT (Admin)
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Device Auth
DEVICE_TOKEN_SECRET=another_long_random_secret_for_device_tokens
DEVICE_TOKEN_EXPIRES_IN=24h

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
DEVICE_RATE_LIMIT_MAX=500

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Admin seed (used only by seed script)
ADMIN_EMAIL=admin@smarthelmet.local
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=System Admin
